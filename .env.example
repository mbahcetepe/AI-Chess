# AI Chess — Yapılandırma Şablonu (.env.example)
#
# ⚠️ ÖNEMLİ: Bu uygulama API anahtarlarını .env'den OKUMAZ.
# Anahtarlar uygulama içinden girilir:  Ayarlar → AI Sağlayıcıları
# ve şuraya kaydedilir:  %APPDATA%\com.murat.chess\settings.json
#
# Bu dosya yalnızca hangi anahtarların kullanıldığını belgeleyen bir ŞABLONDUR.
# Gerçek anahtarlarını buraya yazıp commit ETME (.env zaten .gitignore'da).
# Anahtarları doğrudan uygulamanın Ayarlar ekranına gir.

# --- Bulut AI sağlayıcıları (uygulama Ayarlar'ından girilir) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Ollama (lokal — anahtar gerekmez, sadece adres) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI-uyumlu uç noktalar (Open WebUI / OpenRouter / LM Studio) ---
# Bunlar uygulamada "Rakip Profilleri / Custom Uç Noktalar" olarak eklenir:
#   - Ad, Adres (örn. https://openrouter.ai/api/v1), API Anahtarı
# OPENROUTER_API_KEY=
# OPENWEBUI_API_KEY=
