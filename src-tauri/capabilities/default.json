{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Ana pencere izinleri",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "store:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.openai.com/*" },
        { "url": "https://generativelanguage.googleapis.com/*" },
        { "url": "http://*/*" },
        { "url": "http://*:*/*" },
        { "url": "https://*/*" },
        { "url": "https://*:*/*" }
      ]
    }
  ]
}
