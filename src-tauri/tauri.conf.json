{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Chess",
  "version": "0.1.0",
  "identifier": "com.murat.chess",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Chess",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
