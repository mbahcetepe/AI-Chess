{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Chess",
  "version": "1.0.3",
  "identifier": "com.murat.chess",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Chess",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mbahcetepe/AI-Chess/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwNDc4QUI4NTAyMkJFOTMKUldTVHZpSlF1SXBId0d2UGE3TVBsM28zK2tQRkdlTi9nVlhudHNsa3JhcUx4UUpEc093KzlkbDQK"
    }
  }
}
